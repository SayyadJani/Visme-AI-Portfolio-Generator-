generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}


datasource db {
  provider = "postgresql"
}


// ── Enums ──────────────────────────────────────────────────────────────────

enum ProjectStatus {
  CREATING    // git clone in progress — not usable yet
  READY       // cloned, files on disk, ready to edit and preview
  SLEEPING    // runtime released after idle (files still on disk)
  ERROR       // git clone failed
}

enum SnapshotType {
  AUTO
  MANUAL
  PREDEPLOY
  PRERESTORE
}

// ── Models ─────────────────────────────────────────────────────────────────

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  passwordHash String
  name         String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  projects     Project[]
  resumes      Resume[]
  deployments  Deployment[]

  @@map("users")
}

model Template {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  techStack   String[]
  domain      String
  gitRepoUrl  String    // e.g. "https://github.com/yourorg/template-minimal-dark"
  thumbUrl    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]

  @@map("templates")
}

model Project {
  id            Int           @id @default(autoincrement())
  userId        Int
  templateId    String
  name          String
  diskPath      String        // "/data/instances/42/101" — NEVER send to client
  status        ProjectStatus @default(CREATING)
  previewUrl    String?       // set when preview is active
  lastSavedAt   DateTime?     // updated on every file save
  lastOpenedAt  DateTime?     // updated when IDE is opened
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  template      Template      @relation(fields: [templateId], references: [id])
  deployments   Deployment[]
  snapshots     ProjectSnapshot[]

  @@map("projects")
}

model Resume {
  id         Int      @id @default(autoincrement())
  userId     Int
  parsedJson Json
  rawPath    String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

model Deployment {
  id          Int              @id @default(autoincrement())
  projectId   Int
  userId      Int
  status      DeploymentStatus @default(QUEUED)
  url         String?
  error       String?
  createdAt   DateTime         @default(now())
  completedAt DateTime?
  project     Project          @relation(fields: [projectId], references: [id])
  user        User             @relation(fields: [userId], references: [id])

  @@map("deployments")
}

enum DeploymentStatus {
  QUEUED
  BUILDING
  LIVE
  FAILED
}

model ProjectSnapshot {
  id          Int          @id @default(autoincrement())
  projectId   Int
  type        SnapshotType @default(AUTO)
  label       String?
  filesJson   Json
  fileCount   Int
  sizeBytes   Int
  createdAt   DateTime     @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_snapshots")
}
