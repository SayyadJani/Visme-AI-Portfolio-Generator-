generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  instances Instance[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────
// TEMPLATE
// ─────────────────────────────────────────
model Template {
  id          String     @id @default(uuid())
  name        String
  description String
  thumbnail   String?
  techStack   String
  folderName  String     @unique
  instances   Instance[]
  createdAt   DateTime   @default(now())

  @@map("templates")
}

// ─────────────────────────────────────────
// INSTANCE
// ─────────────────────────────────────────
model Instance {
  id          String         @id @default(uuid())
  name        String
  userId      String
  templateId  String
  status      InstanceStatus @default(ACTIVE)
  deployedUrl String?
  folderPath  String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  template    Template       @relation(fields: [templateId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@map("instances")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────
enum InstanceStatus {
  ACTIVE
  DEPLOYING
  DEPLOYED
  ERROR
}
