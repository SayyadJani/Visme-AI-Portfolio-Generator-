# Server Configuration
PORT=3001
NODE_ENV=production

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/portfolio_db?schema=public"

# Auth
JWT_SECRET=your_jwt_secret_here
SERVER2_INTERNAL_SECRET=your_inter_server_secret

# Infrastructure
REDIS_URL=redis://localhost:6379
SERVER2_URL=http://localhost:3002

# Runtime (The public address where previews are accessible)
# If server2 is on a different VPS, set this to its public IP/Domain
RUNTIME_PUBLIC_HOST=localhost

# Storage & AI
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
GEMINI_API_KEY=your_gemini_key

# OpenAI (Required for "Auto-fill with AI" in the Builder Form Editor)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
